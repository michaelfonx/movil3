<resources>

    <style name="menuItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#333333</item>
        <item name="android:background">?android:attr/selectableItemBackgroundBorderless</item>
    </style>

    <style name="MenuItemTextAppearance">
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#EEEEEE</item>
    </style>
    <style name="inputStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginTop">8dp</item>

        <item name="android:background">@drawable/input_round</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>

        <item name="android:textColor">#333333</item>
        <item name="android:textColorHint">#888888</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>