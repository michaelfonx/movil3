<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:background="#7B1FA2"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

    <LinearLayout
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                card_view:cardCornerRadius="20dp"
                card_view:cardElevation="8dp"
                android:backgroundTint="#FFFFFF">

            <LinearLayout
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                <!-- TÍTULO -->
                <TextView
                        android:text="Confirmar Pago"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                <!-- TOTAL -->
                <TextView
                        android:id="@+id/txtValor"
                        android:text="Total: $0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#7B1FA2"
                        android:layout_marginBottom="16dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                <!-- MÉTODO -->
                <TextView
                        android:text="Método de pago"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                <Spinner
                        android:id="@+id/spinnerMetodo"
                        android:background="@drawable/input_rounded"
                        android:padding="12dp"
                        android:layout_marginTop="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                <!-- EFECTIVO -->
                <LinearLayout
                        android:id="@+id/layoutEfectivo"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                    <TextView
                            android:text="💵 Acércate a un punto de pago"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- TARJETA -->
                <LinearLayout
                        android:id="@+id/layoutTarjeta"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                    <EditText
                            android:id="@+id/etNumero"
                            android:hint="Número de tarjeta"
                            android:background="@drawable/input_rounded"
                            android:padding="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    <EditText
                            android:id="@+id/etNombre"
                            android:hint="Nombre titular"
                            android:background="@drawable/input_rounded"
                            android:padding="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    <EditText
                            android:id="@+id/etFecha"
                            android:hint="MM/AA"
                            android:background="@drawable/input_rounded"
                            android:padding="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    <EditText
                            android:id="@+id/etCVV"
                            android:hint="CVV"
                            android:background="@drawable/input_rounded"
                            android:padding="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    <EditText
                            android:id="@+id/etCuotas"
                            android:hint="Cuotas"
                            android:background="@drawable/input_rounded"
                            android:padding="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- YPSE -->
                <LinearLayout
                        android:id="@+id/layoutYpse"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                    <Spinner
                            android:id="@+id/spinnerYpse"
                            android:background="@drawable/input_rounded"
                            android:padding="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    <EditText
                            android:id="@+id/etCelular"
                            android:hint="Número celular"
                            android:background="@drawable/input_rounded"
                            android:padding="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- BOTÓN -->
                <Button
                        android:id="@+id/btnPagar"
                        android:text="Pagar"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#7B1FA2"
                        android:layout_marginTop="24dp"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>