<androidx.drawerlayout.widget.DrawerLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"

        android:id="@+id/drawer_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:clipChildren="false">

    <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_inicio_morado">

        <FrameLayout
                android:id="@+id/fragmentContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="0dp"/>

        <FrameLayout
                android:id="@+id/customNav"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_alignParentBottom="true"
                android:elevation="20dp"
                android:clipChildren="false"
                android:clipToPadding="false">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_gravity="bottom"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_nav"
                    android:gravity="center"
                    android:padding="8dp">

                <LinearLayout
                        android:id="@+id/nav_inicio"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                    <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/home"
                            android:tint="#FFFFFF"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inicio"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                        android:id="@+id/nav_servicios"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                    <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_store"
                            android:tint="#FFFFFF"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sedes"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                        android:id="@+id/nav_tienda"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                    <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_store"
                            android:tint="#FFFFFF"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tienda"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                        android:id="@+id/nav_pagos"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                    <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_store"
                            android:tint="#FFFFFF"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pagos"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                        android:id="@+id/nav_perfil"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                    <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_user"
                            android:tint="#FFFFFF"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Perfil"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"/>
                </LinearLayout>

            </LinearLayout>

        </FrameLayout>


    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
            android:id="@+id/nav_view"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="@android:color/white"
            android:padding="0dp"
            android:overScrollMode="never"
            android:scrollbars="none"
            app:headerLayout="@layout/menu_lateral_asesor"
            app:itemIconTint="@null"
            app:itemTextAppearance="@style/MenuItemTextAppearance"/>

</androidx.drawerlayout.widget.DrawerLayout>