<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_inicio_morado">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

        <!-- CARD -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_menu"
                android:padding="20dp"
                android:elevation="8dp">

            <!-- TÍTULO -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Actualizar datos"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"/>

            <!-- CAMPOS -->
            <EditText
                    android:id="@+id/edtNombre"
                    android:hint="Primer nombre"
                    style="@style/inputStyle"/>

            <EditText
                    android:id="@+id/edtSegundoNombre"
                    android:hint="Segundo nombre"
                    style="@style/inputStyle"/>

            <EditText
                    android:id="@+id/edtApellido"
                    android:hint="Primer apellido"
                    style="@style/inputStyle"/>

            <EditText
                    android:id="@+id/edtSegundoApellido"
                    android:hint="Segundo apellido"
                    style="@style/inputStyle"/>

            <EditText
                    android:id="@+id/edtDocumento"
                    android:hint="Documento"
                    android:inputType="number"
                    style="@style/inputStyle"/>

            <EditText
                    android:id="@+id/edtCorreo"
                    android:hint="Correo electrónico"
                    android:inputType="textEmailAddress"
                    style="@style/inputStyle"/>

            <EditText
                    android:id="@+id/edtDireccion"
                    android:hint="Dirección"
                    style="@style/inputStyle"/>

            <EditText
                    android:id="@+id/edtPassword"
                    android:hint="Contraseña"
                    android:inputType="textPassword"
                    style="@style/inputStyle"/>

            <!-- BOTÓN -->
            <Button
                    android:id="@+id/btnActualizar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Actualizar información"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/btn_morado"
                    android:textColor="#FFFFFF"/>

            <!-- ELIMINAR -->
            <TextView
                    android:id="@+id/btnEliminar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Eliminar cuenta"
                    android:textColor="#D32F2F"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="16dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>